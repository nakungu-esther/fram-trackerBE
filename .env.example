DATABASE_URL="postgresql://neondb_owner:npg_dBR7rf2GLEwx@ep-bold-salad-ammvrcd9-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
PORT=3000

# Required in production (min 16 random bytes, base64 or hex)
JWT_SECRET="change-me-to-a-long-random-string-in-production"

# Access token lifetime in seconds (default 7 days)
JWT_EXPIRES_SEC=604800

# Optional; bcrypt cost factor (10–14)
BCRYPT_ROUNDS=12

# Optional seed admin (npm run db:seed)
SEED_ADMIN_EMAIL=admin@agritrack.demo
# Defaults to admin123 if unset (same as offline demo). Set something strong in production.
SEED_ADMIN_PASSWORD="admin123"

# ——— Sui (on-chain payment verification) ———
# Must match the frontend VITE_SUI_NETWORK when confirming sales.
# SUI_NETWORK=devnet
# Optional full node override (defaults by network):
# SUI_RPC_URL=https://fullnode.mainnet.sui.io
#
# Verify digests with the chain before marking paid (recommended: true in production).
# SUI_VERIFY_TRANSACTION=true
#
# Minimum SUI (in MIST) the farmer must receive in the tx for confirmation to pass.
# SUI_MIN_PAYMENT_MIST=1
#
# If true, buyer (trader) must have suiAddress on profile and show an outbound debit in the tx.
# SUI_STRICT_SENDER=false
