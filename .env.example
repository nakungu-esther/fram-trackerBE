DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/agritrack?schema=public"
PORT=4000

# Required in production (min 16 random bytes, base64 or hex)
JWT_SECRET="change-me-to-a-long-random-string-in-production"

# Access token lifetime in seconds (default 7 days)
JWT_EXPIRES_SEC=604800

# Optional; bcrypt cost factor (10–14)
BCRYPT_ROUNDS=12

# Optional seed admin (npm run db:seed)
SEED_ADMIN_EMAIL=admin@agritrack.demo
# Defaults to admin123 if unset (same as offline demo). Set something strong in production.
SEED_ADMIN_PASSWORD="admin123"
