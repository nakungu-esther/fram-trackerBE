generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Authenticated accounts (register / login). Passwords stored as bcrypt hashes only.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("farmer")
  name         String
  phone        String?
  location     String?
  suiAddress   String?
  /// Max total outstanding credit (UGX) for this trader; raise via admin/DB for trusted buyers.
  creditLimitUgx Float    @default(1000000)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  procurements Procurement[]
  sales             Sale[]
  salesAsBuyer      Sale[] @relation("BuyerSales")
  farms             Farm[]
  expenses          Expense[]
  seasonalPlans     SeasonalPlan[]
  supplyChainEvents SupplyChainEvent[]
  notificationReads NotificationRead[]
  smsLogs           SmsLog[]
  farmDailyLogs     FarmDailyLog[]
  auditLogs         AuditLog[]
  salesCreated      Sale[]       @relation("SaleCreatedBy")
  salesUpdated      Sale[]       @relation("SaleUpdatedBy")
  procurementsCreated Procurement[] @relation("ProcurementCreatedBy")
  procurementsUpdated Procurement[] @relation("ProcurementUpdatedBy")
}

/// Append-only trace: who changed what (integrity / remote-owner trust).
model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  actorUserId String?
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorEmail  String?
  actorName   String?
  actorRole   String?
  oldValue    Json?
  newValue    Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
}

/// Farmer-submitted daily report: activities, costs, issues, optional photo proof.
model FarmDailyLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  logDate       DateTime
  activities    String
  expenseNote   String?
  expenseAmount Float?
  issues        String?
  photoDataUrl  String?
  createdAt     DateTime @default(now())

  @@index([userId, logDate])
}

model Farm {
  id String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  procurements  Procurement[]
  seasonalPlans SeasonalPlan[]
}

/// Harvests (farm intake). Maps to frontend produce entries; quantity = tonnes.
model Procurement {
  id           Int       @id @default(autoincrement())
  produce      String
  quantity     Float
  price        Float
  farmLocation String?
  userId       String?
  farmId       String?
  date         DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  photoDataUrl String?   @db.Text
  createdByUserId     String?
  lastUpdatedByUserId String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  farm         Farm?     @relation(fields: [farmId], references: [id], onDelete: SetNull)
  createdByUser     User? @relation("ProcurementCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lastUpdatedByUser User? @relation("ProcurementUpdatedBy", fields: [lastUpdatedByUserId], references: [id], onDelete: SetNull)
  sales        Sale[]
}

model Sale {
  id             Int       @id @default(autoincrement())
  produce        String
  quantity       Float
  amount         Float
  buyer          String
  /// pending | paid | partial | credit — pending = awaiting Sui (or manual confirm).
  paymentStatus  String    @default("paid")
  amountPaid     Float?
  creditDueDate  DateTime?
  /// sui = on-chain settlement expected; credit = debt; manual = recorded cash/offline.
  settlementMethod String?
  suiTxDigest    String?   @unique
  /// Trader account that initiated the purchase (marketplace); farmers/admins may leave null.
  buyerUserId    String?
  buyerUser      User?     @relation("BuyerSales", fields: [buyerUserId], references: [id], onDelete: SetNull)
  procurementId  Int?
  procurement    Procurement? @relation(fields: [procurementId], references: [id], onDelete: SetNull)
  userId         String?
  date           DateTime  @default(now())
  recordCreatedAt DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdByUserId     String?
  lastUpdatedByUserId String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdByUser     User? @relation("SaleCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lastUpdatedByUser User? @relation("SaleUpdatedBy", fields: [lastUpdatedByUserId], references: [id], onDelete: SetNull)
}

model Expense {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  amount    Float
  date      DateTime
  createdAt DateTime @default(now())
}

model SeasonalPlan {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  crop                String
  plantDate           DateTime
  expectedHarvestDate DateTime
  farmId              String?
  farm                Farm?    @relation(fields: [farmId], references: [id], onDelete: SetNull)
  notes               String?
  createdAt           DateTime @default(now())
}

/// Supply-chain step; saleId matches client sale id (e.g. api-7 or local s-…).
model SupplyChainEvent {
  id        String   @id @default(cuid())
  saleId    String
  stage     String
  note      String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  at        DateTime @default(now())
}

/// Dismissed / read in-app notifications (keys match computed notification ids in the UI).
model NotificationRead {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  readAt    DateTime @default(now())

  @@unique([userId, key])
}

/// SMS preview log (farmer-centric: userId = account that owns the row).
model SmsLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  to        String
  body      String
  kind      String
  at        DateTime @default(now())
}
